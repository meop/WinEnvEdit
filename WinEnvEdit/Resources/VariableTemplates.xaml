<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
  x:Class="WinEnvEdit.Resources.VariableTemplates"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:converters="using:WinEnvEdit.Converters"
  xmlns:selectors="using:WinEnvEdit.Selectors"
  xmlns:vm="using:WinEnvEdit.ViewModels">

  <!-- Read-Only Variable Template -->
  <DataTemplate x:Key="ReadOnlyTemplate" x:DataType="vm:VariableViewModel">
    <Border Background="{ThemeResource ReadOnlyBackground}"
            BorderBrush="{ThemeResource ReadOnlyBorder}"
            BorderThickness="1"
            CornerRadius="4"
            Margin="4"
            Padding="6"
            Opacity="0.85">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{x:Bind Name, Mode=OneWay}"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Opacity="0.6" />

        <Border Grid.Row="1"
                Margin="0,4,0,0"
                Background="Transparent"
                BorderThickness="0"
                Padding="6,5">
          <TextBlock Text="{x:Bind Value, Mode=OneWay}"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Opacity="0.7"
                     IsTextSelectionEnabled="True" />
        </Border>
      </Grid>
    </Border>
  </DataTemplate>

  <!-- Editable Variable Template -->
  <DataTemplate x:Key="EditableTemplate" x:DataType="vm:VariableViewModel">
    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Margin="4"
            Padding="6">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <TextBlock Grid.Column="0"
                     Text="{x:Bind Name, Mode=OneWay}"
                     FontSize="12"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />

          <Button Grid.Column="1"
                  Content="&#xE74D;"
                  FontFamily="Segoe MDL2 Assets"
                  FontSize="12"
                  Command="{x:Bind DeleteCommand}"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="4"
                  VerticalAlignment="Center"
                  ToolTipService.ToolTip="Delete Variable" />
        </Grid>

        <TextBox Grid.Row="1"
                 Text="{x:Bind Value, Mode=TwoWay}"
                 Margin="0,4,0,0"
                 FontSize="11"
                 Padding="6,5"
                 TextWrapping="Wrap"
                 AcceptsReturn="False" />
      </Grid>
    </Border>
  </DataTemplate>

  <!-- Path-List Variable Template -->
  <DataTemplate x:Key="PathListTemplate" x:DataType="vm:VariableViewModel">
    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Margin="4"
            Padding="6">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <TextBlock Grid.Column="0"
                     Text="{x:Bind Name, Mode=OneWay}"
                     FontSize="12"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />

          <Button Grid.Column="1"
                  Content="{x:Bind IsExpanded, Converter={StaticResource ExpandChevronConverter}, Mode=OneWay}"
                  FontFamily="Segoe MDL2 Assets"
                  FontSize="12"
                  Command="{x:Bind ToggleExpandCommand}"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="4"
                  Margin="2,0"
                  ToolTipService.ToolTip="Expand/Collapse" />

          <Button Grid.Column="2"
                  Content="&#xE74D;"
                  FontFamily="Segoe MDL2 Assets"
                  FontSize="12"
                  Command="{x:Bind DeleteCommand}"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="4"
                  ToolTipService.ToolTip="Delete Variable"
                  Visibility="{x:Bind IsLocked, Converter={StaticResource BoolToVisibilityInverseConverter}, Mode=OneWay}" />
        </Grid>

        <TextBox Grid.Row="1"
                 Text="{x:Bind Value, Mode=TwoWay}"
                 Margin="0,4,0,0"
                 FontSize="11"
                 Padding="6,5"
                 IsReadOnly="{x:Bind VisualIsLocked, Mode=OneWay}"
                 TextWrapping="Wrap"
                 Visibility="{x:Bind IsExpanded, Converter={StaticResource BoolToVisibilityInverseConverter}, Mode=OneWay}" />

        <StackPanel Grid.Row="1"
                    Margin="0,4,0,0"
                    Visibility="{x:Bind IsExpanded, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
          <TextBlock Text="[Path list editing - Phase 4]"
                     FontSize="11"
                     Opacity="0.5"
                     FontStyle="Italic" />
        </StackPanel>
      </Grid>
    </Border>
  </DataTemplate>

  <!-- Template Selector -->
  <selectors:VariableTemplateSelector x:Key="VariableTemplateSelector"
                                       ReadOnlyTemplate="{StaticResource ReadOnlyTemplate}"
                                       EditableTemplate="{StaticResource EditableTemplate}"
                                       PathListTemplate="{StaticResource PathListTemplate}" />
</ResourceDictionary>
